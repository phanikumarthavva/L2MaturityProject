# Copy to .env and set values locally. Never commit .env.

# MongoDB connection string (e.g. mongodb://mongo:27017/prm for Docker Compose)
MONGO_URI=

# Secret used to sign JWTs (use a long random string in production)
JWT_SECRET=

# JWT expiration (e.g. 7d, 24h)
JWT_EXPIRES_IN=

# Server port
PORT=

# Comma-separated origins for CORS (e.g. http://localhost:5173)
CORS_ORIGIN=

# Node environment: development | production
NODE_ENV=

# Optional: seed admin on startup (set to true only when needed)
SEED_ADMIN=

# Optional: email for seeded admin (required if SEED_ADMIN is true)
SEED_ADMIN_EMAIL=

# Optional: password for seeded admin (required if SEED_ADMIN is true)
SEED_ADMIN_PASSWORD=

# Set to true to skip creating the built-in superadmin (superadmin / superadmin) on API startup
DISABLE_DEFAULT_SUPERADMIN=
